# ----- LCD -----
LCD_I2C_ADDRESS=0x27
LCD_ROWS=2
LCD_ENABLED=0

# ----- GPIO (BCM) -----
LED_RED=17
LED_BLUE=27
LED_ACTIVE_HIGH=1

RC522_RST_PIN=25
BLUE_HOLD_SECONDS=5
RANDOM_IDS=1
BUS_POOL=BUS-A,BUS-B,BUS-C

# ----- API -----
API_BASE_URL=http://api:8000

LCD_IDLE_TEXT=Tap card ID
LCD_SUCCESS_TEXT=Updated successfully

# ----- Buzzer -----
BUZZER_PIN=22
BUZZER_TYPE=active
BUZZER_ACTIVE_LOW=false
BUZZER_ENABLED=0

# Optional timings
BUZZER_OK_MS=80
BUZZER_ERROR_MS=200

# Identify which stop this Pi belongs to (for filtering)
ROUTE_ID=R1
STOP_ID=SJSU-ENG-STOP
RANDOM_ROUTE=1
ROUTE_POOL=R1,R2,R3
STOP_POOL=SJSU-ENG-STOP,DOWNTOWN
# Send UID to API so it can track tags
SEND_UID=1


